# ---------------------------------------------------------------------------
# CuidaJunto PWA — environment variables
# Copy this file to `.env` and fill in your own keys. Never commit `.env`.
# All client-side vars MUST be prefixed with VITE_ to be exposed to the app.
# ---------------------------------------------------------------------------

# Clerk (authentication) — https://dashboard.clerk.com
# Used in Phase 2.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (database) — https://supabase.com/dashboard
# Used in Phase 2.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiInR5cCI6xxxxxxxxxxxxxxxxxxxxx

# Web Push (VAPID public key) — used in Phase 4.
# The matching private key stays server-side (Supabase Edge Function secret).
VITE_VAPID_PUBLIC_KEY=

# Deployment base path.
# GitHub Pages project site: "/cuidaJuntoPWA/" (default).
# Custom domain / root: "/"
VITE_BASE_PATH=/cuidaJuntoPWA/
